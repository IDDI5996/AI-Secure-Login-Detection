############################################
# APPLICATION SETTINGS
############################################
APP_NAME="SecureApp"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

############################################
# SECURITY SETTINGS
############################################
BCRYPT_ROUNDS=12
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

############################################
# LOGGING
############################################
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

############################################
# DATABASE CONFIGURATION
############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password

############################################
# SESSION CONFIGURATION
############################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

############################################
# CACHE & QUEUE
############################################
CACHE_STORE=redis
QUEUE_CONNECTION=redis

############################################
# REDIS CONFIGURATION
############################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

############################################
# FILE STORAGE
############################################
FILESYSTEM_DISK=local

############################################
# MAIL CONFIGURATION
############################################
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

############################################
# AWS / CLOUD STORAGE (OPTIONAL)
############################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

############################################
# FRONTEND (VITE)
############################################
VITE_APP_NAME="${APP_NAME}"

############################################
# API SECURITY (FOR AI / SYSTEM INTEGRATION)
############################################
API_RATE_LIMIT=60
API_TOKEN_EXPIRY=60

############################################
# OPTIONAL: SIEM / LOG MONITORING (ADVANCED)
############################################
SIEM_ENABLED=false
SIEM_ENDPOINT=http://localhost:55000
SIEM_API_KEY=

############################################
# OPTIONAL: AI MODEL CONFIGURATION
############################################
AI_MODEL_ENABLED=false
AI_MODEL_PATH=/models/model.pkl
AI_MODEL_API_URL=http://localhost:8000/api/predict